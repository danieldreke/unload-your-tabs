{
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "63.0"
    }
  },
  "background": {
      "scripts": ["tabs-api.js", "background.js"]
  },
  "browser_action": {
    "default_popup": "main.html"
  },
  "description": "Unload your tabs.",
  "manifest_version": 2,
  "name": "Unload Your Tabs",
  "permissions": [
    "tabs",
    "menus",
    "contextMenus"
  ],
  "version": "0.1",
  "icons": {
    "64": "favicon-240.png"
  }
}
