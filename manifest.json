{
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "58.0a1"
    }
  },
  "background": {
      "scripts": ["background.js", "main.js"]
  },
  "browser_action": {
    "browser_style": true,
    "default_popup": "main.html"
  },
  "description": "Unload your tabs.",
  "manifest_version": 2,
  "name": "Unload Your Tabs",
  "permissions": [
    "tabs",
    "menus"
  ],
  "version": "0.1",
  "icons": {
    "64": "icons/favicon-240.png"
  }
}
